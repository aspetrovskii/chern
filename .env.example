# Скопируйте в `.env` и заполните секреты. Файл `.env` в git не коммитится.

# --- Общее ---
APP_BASE_URL=http://127.0.0.1:8000
PROVIDER_MODE=auto
# auto — реальные провайдеры, если заданы креды; иначе mock. real | mock — принудительно.

DB_PATH=data/sqlite.db
LLM_CACHE_DB_PATH=data/llm_cache.db
CRYPTO_KEY=change-me-to-random-32-plus-chars-for-token-encryption

JWT_SECRET=change-me-jwt-secret-at-least-32-bytes-long
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# --- Spotify Web API (OAuth) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/spotify/callback
# Пробелы между scope как в Dashboard; при необходимости сократите список.
SPOTIFY_SCOPES=playlist-read-private playlist-read-collaborative playlist-modify-public playlist-modify-private user-read-email user-read-private streaming user-read-playback-state user-modify-playback-state

# --- YandexGPT (Foundation Models, completion) ---
# Предпочтительно задать полный URI модели:
YANDEX_MODEL_URI=
# Либо папка + идентификатор (если YANDEX_MODEL_URI пуст):
YANDEX_FOLDER_ID=
YANDEX_MODEL_ID=yandexgpt/rc
YANDEX_COMPLETION_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
# Один из двух способов аутентификации (см. README / документацию Yandex Cloud):
YANDEX_API_KEY=
YANDEX_IAM_TOKEN=

# Таймауты и ретраи LLM
LLM_TIMEOUT_SECONDS=45
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BASE_BACKOFF_SECONDS=0.35
LLM_RETRY_MAX_JITTER_SECONDS=0.4
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.2

# Таймауты и ретраи Spotify HTTP
SPOTIFY_HTTP_TIMEOUT_SECONDS=20
SPOTIFY_MAX_RETRIES=3
SPOTIFY_RETRY_BASE_DELAY_SECONDS=0.5
SPOTIFY_RETRY_MAX_JITTER_SECONDS=0.5
